# Copy this file to .env and fill in your values:
#   cp .env.example .env

# Google Cloud
GCP_PROJECT_ID=your-project-id
BQ_DATASET=market_data

# Symbols to ingest (comma-separated)
SYMBOLS_STOCK=AAPL,MSFT,NVDA,SPY
SYMBOLS_CRYPTO=bitcoin,ethereum

# Local only — in Cloud Run, the service account handles auth automatically.
# Create via: gcloud iam service-accounts keys create ./sa-key.json \
#               --iam-account=market-prep-sa@YOUR_PROJECT_ID.iam.gserviceaccount.com
GOOGLE_APPLICATION_CREDENTIALS=./sa-key.json
